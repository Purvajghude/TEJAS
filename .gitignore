# Virtual Environment
venv/
.venv/
.env

# Local machine-specific config (absolute data paths etc.)
config.local.yaml

# Claude Code / agent local state
.claude/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Jupyter
.ipynb_checkpoints/

# VS Code
.vscode/

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
outputs/*.txt
outputs/*.log

# Environment Variables
.env
.env.*

# Build Files
build/
dist/
*.egg-info/

# Test Coverage
.coverage
htmlcov/
.pytest_cache/

# Models (can be large)
models/*.pth
models/*.pt
models/*.pkl

# Data Files (raw payload data + external GOES cache — large, not committed)
data/raw/*
data/processed/*
data/external/*
# fetched/derived data (e.g. SHARP) — regenerate via tools/
data/*.csv

# Generated pipeline outputs (regenerate with `python main.py run`)
outputs/catalogs/*
outputs/processed/*
outputs/models/*
outputs/figures/*
outputs/fusion/*
outputs/forecasting/*
outputs/suit/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample/.gitkeep
!**/.gitkeep

# NetCDF (GOES)
*.nc

# FITS and Scientific Data
*.fits
*.fit
*.lc
*.evt
*.pha   

# Compressed Data
*.zip
*.gz
*.tar
*.tar.gz

# Temporary Files
*.tmp
*.temp