# Virtual Environment
venv/
.venv/
.env

# Local machine-specific config (absolute data paths etc.)
config.local.yaml

# Claude Code / agent local state
.claude/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Jupyter
.ipynb_checkpoints/

# VS Code
.vscode/

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
outputs/*.txt
outputs/*.log

# Environment Variables
.env
.env.*

# Build Files
build/
dist/
*.egg-info/

# Test Coverage
.coverage
htmlcov/
.pytest_cache/

# Models (can be large)
models/*.pth
models/*.pt
models/*.pkl

# Data Files (raw payload data + external GOES cache — large, not committed)
data/raw/*
data/processed/*
data/external/*
# Collab snapshot: derived data (SHARP), observations + all outputs and models ARE
# committed so a collaborator gets everything except the raw archive. data/sharp.csv
# is allowed; only the raw payload (above) and junk logs (below) stay out.

# Only exclude junk run logs from outputs/
outputs/*.txt
outputs/*.log

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample/.gitkeep
!**/.gitkeep

# NetCDF (GOES)
*.nc

# FITS and Scientific Data
*.fits
*.fit
*.lc
*.evt
*.pha   

# Compressed Data
*.zip
*.gz
*.tar
*.tar.gz

# Temporary Files
*.tmp
*.temp